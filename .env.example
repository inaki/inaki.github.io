# Contact form (Resend) — https://resend.com
#
# Local dev (`npm run dev`): copy this file to `.env` and fill in real values.
# Production (Cloudflare Pages): set these as environment variables / secrets
#   e.g. `npx wrangler pages secret put RESEND_API_KEY`
#        and add CONTACT_TO / CONTACT_FROM in the Pages dashboard.

# Resend API key (Settings → API Keys). Required.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact messages are delivered.
CONTACT_TO_EMAIL=hello@inakito.com

# Verified Resend sender on inaki.to (after DNS verify in Resend).
# Until then use onboarding@resend.dev (only delivers to your Resend account email).
CONTACT_FROM_EMAIL=contact@inaki.to
